# ── API ────────────────────────────────────────────────────────────────────────
# Set to "false" when real Tribe V2 model is ready
MOCK_INFERENCE=true

# Storage: "local" | "s3"
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=/tmp/raven_uploads

# S3 (only required when STORAGE_BACKEND=s3)
S3_BUCKET=raven-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Queue: "memory" | "redis" | "sqs"
QUEUE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# Database (SQLite for local dev, Postgres URL for prod)
DATABASE_URL=sqlite:///./raven.db

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ── Web (Next.js) ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
