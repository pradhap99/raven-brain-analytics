# ── API ────────────────────────────────────────────────────────────────────────
# Set to "false" to use the real Tribe V2 model (requires ML dependencies)
MOCK_INFERENCE=true

# Storage: "local" | "s3"
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=/tmp/raven_uploads

# S3 (only required when STORAGE_BACKEND=s3)
S3_BUCKET=raven-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Queue: "memory" | "redis" | "sqs"
QUEUE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# Database (SQLite for local dev, Postgres URL for prod)
DATABASE_URL=sqlite:///./raven.db

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ── Tribe V2 model (only used when MOCK_INFERENCE=false) ──────────────────────
# Path to the .pt checkpoint file containing "head" (and optionally "encoder") keys.
# Leave empty to run in backbone-only proxy mode — no GPU or weights required.
TRIBE_WEIGHTS_PATH=
# Device: "auto" picks CUDA → MPS → CPU automatically
TRIBE_DEVICE=auto
# CLIP vision backbone (HuggingFace model ID, ~350 MB, auto-downloaded on first run)
TRIBE_BACKBONE=openai/clip-vit-base-patch32
# Segment length in seconds (each segment is one inference unit)
TRIBE_SEGMENT_DURATION=1.0
# Frames uniformly sampled from each segment
TRIBE_FRAMES_PER_SEG=8

# ── Result artifacts ───────────────────────────────────────────────────────────
# Local directory where per-job artifacts are stored (timeline PNG, summary JSON)
ARTIFACTS_DIR=/tmp/raven_artifacts
# URL prefix used to build artifact download links returned in AnalysisResult
ARTIFACTS_BASE_URL=http://localhost:8000/v1/artifacts

# ── Video upload validation ────────────────────────────────────────────────────
# Maximum upload size in MB
VIDEO_MAX_SIZE_MB=500
# Maximum video duration in seconds (5 minutes default)
VIDEO_MAX_DURATION_S=300
# Comma-separated list of accepted MIME types
VIDEO_ALLOWED_MIME_TYPES=video/mp4,video/quicktime,video/x-msvideo,video/webm

# ── Optional: custom inference adapter ───────────────────────────────────────
# Fully-qualified class name that implements InferenceAdapter.
# Leave empty to use the default TribeV2Adapter.
# INFERENCE_ADAPTER=mypackage.mymodule.MyAdapter

# ── Web (Next.js) ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
